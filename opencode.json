{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".opencode/instructions.md"],
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask",
    "skill": {
      "*": "ask",
      "terrarium-analyze": "allow"
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".opencode/node_modules/**",
      ".svelte-kit/**",
      "build/**",
      "src-tauri/target/**"
    ]
  }
}
