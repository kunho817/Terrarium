{
  "productName": "Terrarium",
  "version": "0.1.0",
  "identifier": "com.terrarium.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
